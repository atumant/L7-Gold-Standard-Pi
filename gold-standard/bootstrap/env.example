# Gold Standard bootstrap environment example
# Copy to a local non-committed file such as .env.local and adapt.

HOST_PROFILE=pi-openclaw
WG_SUBNET=10.77.0.0/24
WG_SERVER_ADDRESS=10.77.0.1/24
WG_LISTEN_PORT=51820
LAN_SUBNET=192.168.4.0/22
SSH_USER=admin
PRESERVE_PI_CONNECT=true
DISABLE_CUPS=true
DISABLE_RPCBIND=true
DISABLE_AVAHI=true
DISABLE_MODEMMANAGER=true
